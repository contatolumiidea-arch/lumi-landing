.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Large binary assets (add your own via Git LFS instead)
# assets/images/*.jpg
# assets/images/*.png
